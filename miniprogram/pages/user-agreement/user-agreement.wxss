/* pages/user-agreement/user-agreement.wxss */

.page {
  background: #F7F7F7;
  height: 100vh;
}

.container {
  padding: 32rpx 32rpx 80rpx;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #FF6B35, #FF9A5C);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.update-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 简介框 ===== */
.intro-box {
  background: #FFF3EE;
  border-left: 6rpx solid #FF6B35;
  border-radius: 0 16rpx 16rpx 0;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.8;
}

/* ===== 各条款区块 ===== */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 36rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #FFE8DF;
}

.section-body {
  display: block;
  font-size: 26rpx;
  color: #444444;
  line-height: 1.9;
  margin-bottom: 12rpx;
}

.section-body.indent {
  padding-left: 24rpx;
  color: #666666;
}

/* ===== 底部 ===== */
.footer-tip {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #AAAAAA;
}
