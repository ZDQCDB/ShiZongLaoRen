/* pages/index/index.wxss */

/* ===== 顶部横幅 ===== */
.hero-banner {
  background: linear-gradient(135deg, #FF6B35 0%, #FF9A5C 100%);
  padding: 24rpx 32rpx 0;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
}

.hero-left {
  display: flex;
  flex-direction: column;
}

.hero-greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

/* ===== 紧急识别横幅 ===== */
.emergency-bar {
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 20rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.emergency-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.emergency-text {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.emergency-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 主功能网格 ===== */
.page-content {
  padding: 24rpx;
}

.func-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.func-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.func-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.func-search::before {
  background: linear-gradient(90deg, #FF6B35, #FF9A5C);
}

.func-add::before {
  background: linear-gradient(90deg, #4A90D9, #7EC8E3);
}

.func-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.func-icon-orange {
  background: linear-gradient(135deg, #FFF3EE, #FFE0D0);
}

.func-icon-blue {
  background: linear-gradient(135deg, #EBF5FF, #D0E8FF);
}

.func-icon {
  font-size: 48rpx;
}

.func-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 12rpx;
}

.func-desc {
  font-size: 22rpx;
  color: #888888;
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
  margin-bottom: 16rpx;
}

.func-badge {
  background: #FFF3EE;
  color: #FF6B35;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.func-badge-blue {
  background: #EBF5FF;
  color: #4A90D9;
}

/* ===== 统计卡片 ===== */
.stats-card {
  margin-bottom: 24rpx;
}

.stats-header {
  margin-bottom: 0;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #FF6B35;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #888888;
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: #F0F0F0;
}

/* ===== 快速操作 ===== */
.quick-list {
  margin-bottom: 24rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.quick-item:last-child {
  border-bottom: none;
}

.quick-left {
  display: flex;
  align-items: center;
}

.quick-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.quick-text {
  font-size: 30rpx;
  color: #1A1A1A;
}

.quick-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quick-badge {
  background: #FFF3EE;
  color: #FF6B35;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.quick-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ===== 使用提示 ===== */
.tips-card {
  margin-bottom: 24rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  background: #FF6B35;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
}
