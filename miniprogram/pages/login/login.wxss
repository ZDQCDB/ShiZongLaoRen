/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FF6B35 0%, #FF9A5C 30%, #FFF3EE 60%, #F7F7F7 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 0 48rpx;
}

/* ===== 顶部头部 ===== */
.login-header {
  width: 100%;
  padding: 100rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ===== 登录卡片 ===== */
.login-card {
  width: 680rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.card-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.card-subtitle {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.5;
}

/* ===== 功能介绍 ===== */
.feature-list {
  margin-bottom: 48rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 64rpx;
  text-align: center;
}

.feature-text {
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #888888;
}

/* ===== 微信登录按钮 ===== */
.btn-wechat-login {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #09A54F);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  border: none;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
  letter-spacing: 2rpx;
}

.btn-wechat-login::after {
  border: none;
}

.wechat-icon {
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

/* ===== 提示文字 ===== */
.login-tip-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 4rpx;
}

.login-tip-text {
  font-size: 22rpx;
  color: #AAAAAA;
  line-height: 1.6;
}

.link-text {
  font-size: 22rpx;
  color: #FF6B35;
  line-height: 1.6;
  text-decoration: underline;
}

.login-tip {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
  text-align: center;
  line-height: 1.6;
  margin-top: 4rpx;
}

/* ===== 底部 ===== */
.login-footer {
  margin-top: 48rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
}
