/* pages/tcm-consult/tcm-consult.wxss */

page {
  background: #FFF8F5;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ===== 顶部工具栏 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #FFE8DC;
}

.type-switch {
  display: flex;
  background: #FFF3EE;
  border-radius: 32rpx;
  padding: 4rpx;
}

.type-btn {
  padding: 10rpx 32rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s;
}

.type-btn-active {
  background: #FF6B35;
  color: #FFFFFF;
  font-weight: 600;
}

.toolbar {
  display: flex;
  gap: 16rpx;
}

.toolbar-btn {
  font-size: 24rpx;
  color: #FF6B35;
  padding: 8rpx 20rpx;
  border: 1rpx solid #FF6B35;
  border-radius: 20rpx;
}

/* ===== 免责声明 ===== */
.disclaimer {
  background: #FFF8E1;
  padding: 12rpx 28rpx;
  border-bottom: 1rpx solid #FFE082;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #795548;
  line-height: 1.5;
}

/* ===== 聊天区域 ===== */
.chat-area {
  flex: 1;
  overflow: hidden;
}

.chat-inner {
  padding: 24rpx 20rpx 20rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.msg-row-user {
  justify-content: flex-end;
}

.msg-row-ai {
  justify-content: flex-start;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.avatar-ai {
  background: #FFF3EE;
  margin-right: 16rpx;
}

.avatar-user {
  background: #E3F2FD;
  margin-left: 16rpx;
}

.bubble {
  max-width: 560rpx;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}

.bubble-ai {
  background: #FFFFFF;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.bubble-user {
  background: #FF6B35;
  border-top-right-radius: 4rpx;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.bubble-ai .bubble-text {
  color: #333333;
}

.bubble-user .bubble-text {
  color: #FFFFFF;
}

/* ===== 加载动画 ===== */
.loading-dots {
  display: flex;
  align-items: center;
  padding: 16rpx 108rpx;
  gap: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF6B35;
  border-radius: 50%;
  opacity: 0.3;
  animation: dotPulse 1.2s infinite;
}

.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* ===== 快捷标签栏 ===== */
.tags-bar {
  background: #FFFFFF;
  border-top: 1rpx solid #FFE8DC;
  padding: 16rpx 0;
  white-space: nowrap;
}

.tags-inner {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.tag {
  display: inline-block;
  background: #FFF3EE;
  color: #FF6B35;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid #FFD4C2;
}

/* ===== 输入区域 ===== */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #FFE8DC;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  color: #333333;
  min-height: 72rpx;
  line-height: 1.4;
}

.send-btn {
  width: 100rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.send-btn-active {
  background: #FF6B35;
  color: #FFFFFF;
}

.send-btn-disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

/* ===== 历史记录弹层 ===== */
.history-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.history-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.history-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.history-close {
  font-size: 32rpx;
  color: #999999;
  padding: 8rpx;
}

.history-list {
  flex: 1;
  padding: 16rpx 28rpx;
}

.history-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #AAAAAA;
}

.history-item {
  background: #FFF8F5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #FF6B35;
}

.history-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.history-tag {
  font-size: 22rpx;
  background: #FFF3EE;
  color: #FF6B35;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.history-time {
  font-size: 22rpx;
  color: #AAAAAA;
}

.history-symptom {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.history-advice-preview {
  display: block;
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
