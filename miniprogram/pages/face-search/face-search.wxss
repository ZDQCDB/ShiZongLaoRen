/* pages/face-search/face-search.wxss */

/* ===== 顶部区域 ===== */
.search-header {
  background: linear-gradient(135deg, #FF6B35, #FF9A5C);
  padding: 48rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
  white-space: pre-line;
}

/* ===== 上传区域 ===== */
.upload-card {
  margin-bottom: 24rpx;
}

.upload-area {
  border: 3rpx dashed #DDDDDD;
  border-radius: 16rpx;
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FAFAFA;
  transition: border-color 0.2s;
}

.upload-area:active {
  border-color: #FF6B35;
  background: #FFF3EE;
}

.upload-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #AAAAAA;
  text-align: center;
}

/* ===== 照片预览 ===== */
.preview-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-img {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
  object-fit: cover;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.preview-actions {
  display: flex;
  gap: 24rpx;
}

.preview-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.preview-btn-change {
  background: #FFF3EE;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.preview-btn-clear {
  background: #FFF5F5;
  color: #FF4D4F;
  border: 2rpx solid #FF4D4F;
}

/* ===== 搜索按钮 ===== */
.search-btn {
  margin-bottom: 24rpx;
  height: 96rpx;
  font-size: 32rpx;
}

/* ===== 识别结果 ===== */
.result-card {
  margin-bottom: 24rpx;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.result-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.result-title-wrap {
  display: flex;
  flex-direction: column;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.result-confidence {
  font-size: 24rpx;
  color: #52C41A;
  font-weight: 600;
  margin-top: 4rpx;
}

/* 识别成功样式 */
.result-success {
  border: 2rpx solid #B7EB8F;
  background: linear-gradient(to bottom, #F6FFED, #FFFFFF);
}

/* 识别失败样式 */
.result-fail {
  border: 2rpx solid #FFCCC7;
  background: linear-gradient(to bottom, #FFF2F0, #FFFFFF);
}

/* ===== 老人信息展示 ===== */
.elder-result-info {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: #F9F9F9;
  border-radius: 16rpx;
}

.result-photo-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #FFF3E0;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.result-photo-icon {
  font-size: 64rpx;
  line-height: 1;
}

.result-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  object-fit: cover;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.result-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.result-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.result-gender-age {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.result-address {
  font-size: 24rpx;
  color: #888888;
}

/* ===== 联系信息 ===== */
.result-contact {
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: #FFF3EE;
  border-radius: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.contact-item:last-child {
  margin-bottom: 0;
}

.contact-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #888888;
}

.contact-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.contact-phone {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B35;
  letter-spacing: 2rpx;
}

/* ===== 操作按钮 ===== */
.call-btn {
  margin-bottom: 16rpx;
  height: 96rpx;
  font-size: 32rpx;
}

.detail-btn {
  height: 80rpx;
  font-size: 28rpx;
  margin-bottom: 0;
}

.call-police-btn {
  margin-top: 24rpx;
  height: 96rpx;
  font-size: 32rpx;
}

/* ===== 失败提示 ===== */
.result-message {
  font-size: 28rpx;
  color: #FF4D4F;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.suggest-list {
  padding: 24rpx;
  background: #FFF2F0;
  border-radius: 12rpx;
}

.suggest-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.suggest-item {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
}

/* ===== 使用提示区域 ===== */
.tips-section {
  margin-bottom: 32rpx;
}

.tip-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.tip-row:last-child {
  border-bottom: none;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.tip-content {
  flex: 1;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
}
