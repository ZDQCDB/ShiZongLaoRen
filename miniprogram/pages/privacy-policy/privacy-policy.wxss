/* pages/privacy-policy/privacy-policy.wxss */

.page {
  background: #F7F7F7;
  height: 100vh;
}

.container {
  padding: 32rpx 32rpx 80rpx;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #1A73E8, #4FA3F7);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.update-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 简介框 ===== */
.intro-box {
  background: #EAF3FF;
  border-left: 6rpx solid #1A73E8;
  border-radius: 0 16rpx 16rpx 0;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.8;
}

/* ===== 各条款区块 ===== */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 36rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.highlight-section {
  background: #F0FFF4;
  border: 2rpx solid #C3E6CB;
}

.special-section {
  background: #FFF8E1;
  border: 2rpx solid #FFE082;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1A73E8;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E3F2FD;
}

.highlight-section .section-title {
  color: #2E7D32;
  border-bottom-color: #C8E6C9;
}

.special-section .section-title {
  color: #E65100;
  border-bottom-color: #FFE0B2;
}

.section-body {
  display: block;
  font-size: 26rpx;
  color: #444444;
  line-height: 1.9;
  margin-bottom: 12rpx;
}

.bold {
  font-weight: 700;
  color: #1A1A1A;
}

/* ===== 信息卡片（收集信息区域）===== */
.info-card {
  background: #F8FBFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #4FA3F7;
}

.info-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A73E8;
  margin-bottom: 8rpx;
}

.info-card-body {
  display: block;
  font-size: 25rpx;
  color: #555555;
  line-height: 1.7;
  margin-bottom: 8rpx;
}

.info-card-purpose {
  display: block;
  font-size: 24rpx;
  color: #888888;
  background: #EAF3FF;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* ===== 联系方式 ===== */
.contact-item {
  padding: 12rpx 0;
}

/* ===== 底部 ===== */
.footer-tip {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #AAAAAA;
}
