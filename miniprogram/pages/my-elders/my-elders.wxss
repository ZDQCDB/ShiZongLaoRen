/* pages/my-elders/my-elders.wxss */

/* ===== 顶部 ===== */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.list-header-content {
  display: flex;
  flex-direction: column;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.list-count {
  font-size: 24rpx;
  color: #AAAAAA;
  margin-top: 4rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FF6B35, #FF9A5C);
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.add-btn-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 300;
  margin-right: 8rpx;
  line-height: 1;
}

.add-btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ===== 老人卡片 ===== */
.page-content {
  padding: 20rpx 24rpx;
}

.elder-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
}

/* ===== 照片 ===== */
.elder-photo-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.elder-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 3rpx solid #F0F0F0;
}

.elder-photo-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE0D0, #FFEEE5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.face-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  border: 3rpx solid #FFFFFF;
}

.face-badge-ok {
  background: #52C41A;
  color: #FFFFFF;
}

.face-badge-no {
  background: #FAAD14;
  color: #FFFFFF;
}

/* ===== 老人信息 ===== */
.elder-info {
  flex: 1;
  overflow: hidden;
}

.elder-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.elder-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-right: 16rpx;
}

.elder-gender-age {
  font-size: 22rpx;
  color: #888888;
  background: #F5F5F5;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.elder-address-row,
.elder-phone-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.elder-addr-icon,
.elder-phone-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  width: 28rpx;
}

.elder-address {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.elder-phone {
  font-size: 24rpx;
  color: #666666;
}

.no-face-tip {
  font-size: 20rpx;
  color: #FAAD14;
  margin-top: 8rpx;
}

.elder-arrow {
  font-size: 44rpx;
  color: #CCCCCC;
  font-weight: 300;
  margin-left: 8rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #AAAAAA;
  margin-bottom: 48rpx;
}

.empty-add-btn {
  width: 300rpx;
  height: 88rpx;
  font-size: 30rpx;
}

/* ===== 加载 ===== */
.loading-row {
  text-align: center;
  padding: 48rpx;
  color: #AAAAAA;
  font-size: 26rpx;
}
