/* pages/elder-detail/elder-detail.wxss */

/* ===== 顶部大照片 ===== */
.detail-hero {
  background: linear-gradient(160deg, #FF6B35 0%, #FF9A5C 100%);
  padding: 48rpx 32rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-photo-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.7);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.detail-photo {
  width: 100%;
  height: 100%;
}

.detail-photo-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-photo-icon {
  font-size: 100rpx;
}

.detail-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.detail-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.detail-gender-badge {
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  color: #FFFFFF;
}

.badge-male { background: rgba(74, 144, 217, 0.4); }
.badge-female { background: rgba(255, 107, 180, 0.4); }

.detail-age {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ===== 紧急联系卡片 ===== */
.emergency-contact-card {
  border: 2rpx solid #FFD6C8;
  background: linear-gradient(to bottom, #FFF8F5, #FFFFFF);
  margin-bottom: 24rpx;
}

.ec-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ec-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.ec-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B35;
}

.ec-person {
  margin-bottom: 8rpx;
}

.ec-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.ec-relation {
  font-size: 24rpx;
  color: #888888;
  font-weight: normal;
}

.ec-phone {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FF6B35;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.call-btn {
  height: 96rpx;
  font-size: 32rpx;
}

/* ===== 健康信息 ===== */
.health-content {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  border-left: 6rpx solid #FAAD14;
}

.health-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.health-text {
  flex: 1;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
}

/* ===== 备注 ===== */
.addition-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
}

/* ===== 录入信息 ===== */
.uploader-card {
  padding: 24rpx 32rpx;
}

.uploader-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.uploader-row:last-child { border-bottom: none; }

.uploader-label {
  width: 140rpx;
  font-size: 24rpx;
  color: #AAAAAA;
}

.uploader-value {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
}

/* ===== 操作按钮 ===== */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  border-radius: 16rpx;
}

/* ===== 人脸注册数量徽章 ===== */
.face-count-badge {
  margin-top: 12rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
}

.face-count-ok {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.face-count-none {
  background: rgba(255, 200, 0, 0.3);
  color: #FFF3CC;
}

/* ===== 加载 ===== */
.loading-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #AAAAAA;
  font-size: 28rpx;
}
